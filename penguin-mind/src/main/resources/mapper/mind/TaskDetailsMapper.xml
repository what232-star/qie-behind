<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.penguin.mind.mapper.TaskDetailsMapper">
    
    <resultMap type="TaskDetails" id="TaskDetailsResult">
        <result property="detailsId"    column="details_id"    />
        <result property="taskId"    column="task_id"    />
        <result property="channelCode"    column="channel_code"    />
        <result property="expectCapacity"    column="expect_capacity"    />
        <result property="penguinId"    column="penguin_id"    />
        <result property="penguinName"    column="penguin_name"    />
        <result property="penguinImage"    column="penguin_image"    />
    </resultMap>

    <sql id="selectTaskDetailsVo">
        select details_id, task_id, channel_code, expect_capacity, penguin_id, penguin_name, penguin_image from tb_task_details
    </sql>

    <select id="selectTaskDetailsList" parameterType="TaskDetails" resultMap="TaskDetailsResult">
        <include refid="selectTaskDetailsVo"/>
        <where>  
            <if test="taskId != null "> and task_id = #{taskId}</if>
            <if test="channelCode != null  and channelCode != ''"> and channel_code = #{channelCode}</if>
            <if test="expectCapacity != null "> and expect_capacity = #{expectCapacity}</if>
            <if test="penguinId != null "> and penguin_id = #{penguinId}</if>
            <if test="penguinName != null  and penguinName != ''"> and penguin_name like concat('%', #{penguinName}, '%')</if>
            <if test="penguinImage != null  and penguinImage != ''"> and penguin_image = #{penguinImage}</if>
        </where>
    </select>
    
    <select id="selectTaskDetailsByDetailsId" parameterType="Long" resultMap="TaskDetailsResult">
        <include refid="selectTaskDetailsVo"/>
        where details_id = #{detailsId}
    </select>

    <insert id="insertTaskDetails" parameterType="TaskDetails" useGeneratedKeys="true" keyProperty="detailsId">
        insert into tb_task_details
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="taskId != null">task_id,</if>
            <if test="channelCode != null">channel_code,</if>
            <if test="expectCapacity != null">expect_capacity,</if>
            <if test="penguinId != null">penguin_id,</if>
            <if test="penguinName != null">penguin_name,</if>
            <if test="penguinImage != null">penguin_image,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="taskId != null">#{taskId},</if>
            <if test="channelCode != null">#{channelCode},</if>
            <if test="expectCapacity != null">#{expectCapacity},</if>
            <if test="penguinId != null">#{penguinId},</if>
            <if test="penguinName != null">#{penguinName},</if>
            <if test="penguinImage != null">#{penguinImage},</if>
         </trim>
    </insert>


    <!-- ... existing code  批量新增 ... -->

    <insert id="batchInsertTaskDetails" parameterType="java.util.List">
        insert into tb_task_details (task_id, channel_code, expect_capacity, penguin_id, penguin_name, penguin_image)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.taskId}, #{item.channelCode}, #{item.expectCapacity}, #{item.penguinId}, #{item.penguinName}, #{item.penguinImage})
        </foreach>
    </insert>

    <!-- ... existing code ... -->


    <update id="updateTaskDetails" parameterType="TaskDetails">
        update tb_task_details
        <trim prefix="SET" suffixOverrides=",">
            <if test="taskId != null">task_id = #{taskId},</if>
            <if test="channelCode != null">channel_code = #{channelCode},</if>
            <if test="expectCapacity != null">expect_capacity = #{expectCapacity},</if>
            <if test="penguinId != null">penguin_id = #{penguinId},</if>
            <if test="penguinName != null">penguin_name = #{penguinName},</if>
            <if test="penguinImage != null">penguin_image = #{penguinImage},</if>
        </trim>
        where details_id = #{detailsId}
    </update>

    <delete id="deleteTaskDetailsByDetailsId" parameterType="Long">
        delete from tb_task_details where details_id = #{detailsId}
    </delete>

    <delete id="deleteTaskDetailsByDetailsIds" parameterType="String">
        delete from tb_task_details where details_id in 
        <foreach item="detailsId" collection="array" open="(" separator="," close=")">
            #{detailsId}
        </foreach>
    </delete>
</mapper>