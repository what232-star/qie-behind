<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.penguin.mind.mapper.PenguinClassMapper">
    
    <resultMap type="PenguinClass" id="PenguinClassResult">
        <result property="classId"    column="class_id"    />
        <result property="className"    column="class_name"    />
        <result property="parentId"    column="parent_id"    />
    </resultMap>

    <sql id="selectPenguinClassVo">
        select class_id, class_name, parent_id from tb_penguin_class
    </sql>

    <select id="selectPenguinClassList" parameterType="PenguinClass" resultMap="PenguinClassResult">
        <include refid="selectPenguinClassVo"/>
        <where>  
            <if test="className != null  and className != ''"> and class_name like concat('%', #{className}, '%')</if>
        </where>
    </select>
    
    <select id="selectPenguinClassByClassId" parameterType="Long" resultMap="PenguinClassResult">
        <include refid="selectPenguinClassVo"/>
        where class_id = #{classId}
    </select>

    <insert id="insertPenguinClass" parameterType="PenguinClass">
        insert into tb_penguin_class
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="classId != null">class_id,</if>
            <if test="className != null and className != ''">class_name,</if>
            <if test="parentId != null">parent_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="classId != null">#{classId},</if>
            <if test="className != null and className != ''">#{className},</if>
            <if test="parentId != null">#{parentId},</if>
         </trim>
    </insert>

    <update id="updatePenguinClass" parameterType="PenguinClass">
        update tb_penguin_class
        <trim prefix="SET" suffixOverrides=",">
            <if test="className != null and className != ''">class_name = #{className},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
        </trim>
        where class_id = #{classId}
    </update>

    <delete id="deletePenguinClassByClassId" parameterType="Long">
        delete from tb_penguin_class where class_id = #{classId}
    </delete>

    <delete id="deletePenguinClassByClassIds" parameterType="String">
        delete from tb_penguin_class where class_id in 
        <foreach item="classId" collection="array" open="(" separator="," close=")">
            #{classId}
        </foreach>
    </delete>
</mapper>